// ================== Login ==================
bool adminLogin() {
    string user, pass;
    cout << "Enter Admin Username: "; cin >> user;
    cout << "Enter Admin Password: "; cin >> pass;

    ifstream fin("admin.txt");
    if (!fin) {
        cout << "Admin file not found. Creating default admin (admin/admin123)\n";
        ofstream fout("admin.txt");
        fout << "admin admin123\n";
        fout.close();
        return (user == "admin" && pass == "admin123");
    }

    string fileUser, filePass;
    while (fin >> fileUser >> filePass) {
        if (user == fileUser && pass == filePass) {
            fin.close();
            return true;
        }
    }
    fin.close();
    return false;
}


void studentLogin() {
    string username, password;
    cout << "Enter Username: "; cin >> username;
    cout << "Enter Password: "; cin >> password;

    vector<Student> students = loadStudents();
    for (auto &s : students) {
        if (s.username == username && s.password == password) {
            cout << "Login successful! Welcome, " << s.name << endl;
            studentMenu(s);
            return;
        }
    }
    cout << "Invalid student credentials!\n";
}

