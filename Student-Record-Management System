void updateStudent() {
    vector<Student> students = loadStudents();
    if (students.empty()) {
        cout << "\nNo students available to update!\n";
        return;
    }

    int id;
    cout << "Enter Student ID to update: ";
    cin >> id;

    bool found = false;
    for (auto &s : students) {
        if (s.id == id) {
            found = true;
            cout << "Updating record for " << s.name << endl;

            cout << "Enter new Name: "; cin.ignore(); getline(cin, s.name);
            cout << "Enter new Age: "; cin >> s.age;
            cout << "Enter new Course: "; cin.ignore(); getline(cin, s.course);
            cout << "Enter new GPA: "; cin >> s.gpa;
            cout << "Enter new Username: "; cin >> s.username;
            cout << "Enter new Password: "; cin >> s.password;
            cout << "Enter new Contact: "; cin >> s.contact;

            cout << "Record updated successfully!\n";
            break;
        }
    }

    if (!found) {
        cout << "Student with ID " << id << " not found.\n";
        return;
    }

    // Save all students back to file
    ofstream fout("students.txt");
    for (auto &s : students) {
        fout << s.id << "," << s.name << "," << s.age << "," << s.course << ","
             << s.gpa << "," << s.username << "," << s.password << "," << s.contact << endl;
    }
    fout.close();
}
void deleteStudent() {
    vector<Student> students = loadStudents();
    if (students.empty()) {
        cout << "\nNo students available to delete!\n";
        return;
    }

    int id;
    cout << "Enter Student ID to delete: ";
    cin >> id;

    bool found = false;
    vector<Student> updatedList;

    for (auto &s : students) {
        if (s.id == id) {
            found = true;
            cout << "Deleting record for " << s.name << endl;
            continue; // skip this student
        }
        updatedList.push_back(s);
    }

    if (!found) {
        cout << "Student with ID " << id << " not found.\n";
        return;
    }

    // Save updated student list
    ofstream fout("students.txt");
    for (auto &s : updatedList) {
        fout << s.id << "," << s.name << "," << s.age << "," << s.course << ","
             << s.gpa << "," << s.username << "," << s.password << "," << s.contact << endl;
    }
    fout.close();

    // 🔹 ALSO remove their attendance records
    ifstream fin("attendance.txt");
    ofstream temp("temp.txt");
    string line;
    while (getline(fin, line)) {
        if (line.empty()) continue;
        stringstream ss(line);
        string token, date, status;
        int sid;
        getline(ss, token, ','); sid = stoi(token);
        getline(ss, date, ',');
        getline(ss, status, ',');
        if (sid != id) {  // keep only attendance of other students
            temp << sid << "," << date << "," << status << endl;
        }
    }
    fin.close();
    temp.close();

    remove("attendance.txt");         // delete old file
    rename("temp.txt", "attendance.txt");  // replace with updated

    cout << "Record and related attendance deleted successfully!\n";
}
void cleanAttendanceFile() {
    ifstream fin("attendance.txt");
    if (!fin) {
        cout << "No attendance file found.\n";
        return;
    }

    // Use map to store only the latest record for (studentId, date)
    map<pair<int,string>, string> latest;
    string line;

    while (getline(fin, line)) {
        if (line.empty()) continue;
        stringstream ss(line);
        string token, date, status;
        int sid;
        getline(ss, token, ','); sid = stoi(token);
        getline(ss, date, ',');
        getline(ss, status, ',');

        // overwrite old value → keeps last record for same student & date
        latest[{sid, date}] = status;
    }
    fin.close();

    // Now write ONLY cleaned data back
    ofstream fout("attendance.txt", ios::out | ios::trunc);
    for (auto &entry : latest) {
        fout << entry.first.first << ","   // Student ID
             << entry.first.second << ","  // Date
             << entry.second << endl;      // Status
    }
    fout.close();

    cout << "✅ Attendance file cleaned successfully! Duplicates removed.\n";
}




