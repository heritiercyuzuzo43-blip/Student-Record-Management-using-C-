// ================== Student Class ==================
class Student {
public:
    int id;
    string name;
    int age;
    string course;
    double gpa;
    string username;
    string password;
    string contact;

    Student() {}
    Student(int i, string n, int a, string c, double g, string u, string p, string con) {
        id = i; name = n; age = a; course = c; gpa = g;
        username = u; password = p; contact = con;
    }

    void display() {
        cout << "ID: " << id << " | Name: " << name
             << " | Age: " << age << " | Course: " << course
             << " | GPA: " << gpa << " | Contact: " << contact << endl;
    }
};

// ================== File Handling ==================
void saveStudent(Student s) {
    ofstream fout("students.txt", ios::app);
    fout << s.id << "," << s.name << "," << s.age << "," << s.course << ","
         << s.gpa << "," << s.username << "," << s.password << "," << s.contact << endl;
    fout.close();
}

vector<Student> loadStudents() {
    vector<Student> students;
    ifstream fin("students.txt");
    string line;
    while (getline(fin, line)) {
        if(line.empty()) continue;
        stringstream ss(line);
        string token;
        Student s;
        getline(ss, token, ','); s.id = stoi(token);
        getline(ss, s.name, ',');
        getline(ss, token, ','); s.age = stoi(token);
        getline(ss, s.course, ',');
        getline(ss, token, ','); s.gpa = stod(token);
        getline(ss, s.username, ',');
        getline(ss, s.password, ',');
        getline(ss, s.contact, ',');
        students.push_back(s);
    }
    fin.close();
    return students;
}

// ================== Attendance Handling ==================
void markAttendance(int studentId, string date, string status) {
    ifstream fin("attendance.txt");
    vector<string> records;
    string line;
    bool updated = false;

    while (getline(fin, line)) {
        if (line.empty()) continue;
        stringstream ss(line);
        string token, d, st;
        int sid;
        getline(ss, token, ','); sid = stoi(token);
        getline(ss, d, ',');
        getline(ss, st, ',');

        if (sid == studentId && d == date) {
            // Overwrite old record for same student & date
            line = to_string(sid) + "," + date + "," + status;
            updated = true;
        }
        records.push_back(line);
    }
    fin.close();

    // If no record existed, add a new one
    if (!updated) {
        records.push_back(to_string(studentId) + "," + date + "," + status);
    }

    // Rewrite the file cleanly
    ofstream fout("attendance.txt", ios::out | ios::trunc);
    for (auto &rec : records) {
        fout << rec << endl;
    }
    fout.close();

    if (updated)
        cout << "✅ Attendance updated for Student " << studentId << " on " << date << endl;
    else
        cout << "✅ Attendance marked for Student " << studentId << " on " << date << endl;
}


void viewAttendance(int studentId) {
    ifstream fin("attendance.txt");
    if (!fin) {
        cout << "No attendance records found.\n";
        return;
    }

    map<string, string> records; // date -> status (latest only)
    string line;
    while (getline(fin, line)) {
        if (line.empty()) continue;
        stringstream ss(line);
        string token, date, status;
        int id;
        getline(ss, token, ','); id = stoi(token);
        getline(ss, date, ',');
        getline(ss, status, ',');
        if (id == studentId) {
            records[date] = status; // overwrite if duplicate
        }
    }
    fin.close();

    cout << "\nAttendance for Student ID " << studentId << ":\n";
    if (records.empty()) {
        cout << "No attendance records found.\n";
        return;
    }
    for (auto &r : records) {
        cout << r.first << " -> " << r.second << endl;
    }
}

